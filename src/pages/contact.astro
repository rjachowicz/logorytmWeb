---
import Layout from '../layouts/Layout.astro';

const galleryImages = [
    {
        src: 'https://images.unsplash.com/photo-1629904853716-f0bc54eea481?auto=format&fit=crop&q=80&w=1200',
        alt: 'Gabinet Logopedyczny - wnętrze'
    },
    {
        src: 'https://images.unsplash.com/photo-1516627145497-ae6968895b74?auto=format&fit=crop&q=80&w=1200',
        alt: 'Pomoce logopedyczne'
    },
    {
        src: 'https://images.unsplash.com/photo-1527515637462-cff94eecc1ac?auto=format&fit=crop&q=80&w=1200',
        alt: 'Kącik dla dziecka'
    },
    {
        src: 'https://images.unsplash.com/photo-1573497019940-1c28c88b4f3e?auto=format&fit=crop&q=80&w=1200',
        alt: 'Sprzęt do terapii'
    }
];
---

<Layout title="Kontakt i Gabinet">
    <section class="relative pt-32 pb-16 overflow-hidden">
        <div class="max-w-7xl mx-auto px-6 text-center relative z-10 reveal-up">
            <span class="inline-block py-1.5 px-4 rounded-full bg-white/40 backdrop-blur-md border border-[#C38154]/30 text-[#884A39] font-bold tracking-widest uppercase text-xs mb-6 shadow-sm">
                Zapraszam do kontaktu
            </span>
            <h1 class="font-heading font-extrabold text-5xl md:text-6xl text-[#884A39] leading-tight mb-8">
                Poznajmy się <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#C38154] to-[#FFC26F]">bliżej.</span>
            </h1>
        </div>
    </section>

    <section class="pb-24 relative z-10">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-8 lg:gap-12 items-stretch">

                <div class="flex flex-col gap-6 reveal-left">
                    <div class="bg-white/60 backdrop-blur-md p-8 md:p-10 rounded-[3rem] border border-white shadow-xl flex-1">
                        <h2 class="font-heading font-bold text-3xl text-[#884A39] mb-8">Dane kontaktowe</h2>

                        <div class="space-y-8">
                            <div class="flex items-start gap-5">
                                <div class="w-12 h-12 shrink-0 rounded-2xl bg-[#C38154]/10 flex items-center justify-center text-[#C38154]">
                                    <svg aria-hidden="true" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-[#884A39]/50 uppercase tracking-widest mb-1">
                                        Telefon</p>
                                    <a href="tel:+48504759254"
                                       class="text-xl font-bold text-[#884A39] hover:text-[#C38154] transition-colors">+48
                                        504 759 254</a>
                                </div>
                            </div>

                            <div class="flex items-start gap-5">
                                <div class="w-12 h-12 shrink-0 rounded-2xl bg-[#FFC26F]/10 flex items-center justify-center text-[#FFC26F]">
                                    <svg aria-hidden="true" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-[#884A39]/50 uppercase tracking-widest mb-1">
                                        Email</p>
                                    <a href="mailto:kontaktlogorytm@gmail.com"
                                       class="text-xl font-bold text-[#884A39] hover:text-[#FFC26F] transition-colors break-all">kontaktlogorytm@gmail.com</a>
                                </div>
                            </div>

                            <div class="flex items-start gap-5">
                                <div class="w-12 h-12 shrink-0 rounded-2xl bg-[#884A39]/10 flex items-center justify-center text-[#884A39]">
                                    <svg aria-hidden="true" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                                    </svg>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-[#884A39]/50 uppercase tracking-widest mb-1">
                                        Gabinet</p>
                                    <p class="text-xl font-bold text-[#884A39]">Łęka 184, 33-322 Korzenna</p>
                                </div>
                            </div>
                        </div>

                        <div class="mt-12 pt-8 border-t border-[#884A39]/10">
                            <p class="text-sm font-bold text-[#884A39]/50 uppercase tracking-widest mb-6">Znajdziesz mnie również tutaj:</p>
                            <div class="flex flex-col sm:flex-row gap-4">
                                <a href="https://www.facebook.com/profile.php?id=61574499106160" target="_blank" rel="noopener noreferrer"
                                   class="flex items-center justify-center gap-3 bg-[#1877F2]/10 text-[#1877F2] py-4 px-6 rounded-2xl font-bold hover:bg-[#1877F2] hover:text-white transition-all group">
                                    <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                                    </svg>
                                    Facebook
                                </a>

                                <a href="https://wa.me/48504759254" target="_blank" rel="noopener noreferrer"
                                   class="flex items-center justify-center gap-3 bg-[#25D366]/10 text-[#25D366] py-4 px-6 rounded-2xl font-bold hover:bg-[#25D366] hover:text-white transition-all group">
                                    <svg aria-hidden="true" class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L0 24l6.335-1.662c1.72.937 3.659 1.432 5.628 1.433h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413Z"/>
                                    </svg>
                                    WhatsApp
                                </a>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="h-full reveal-right">
                    <div class="w-full h-full min-h-[450px] rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white/60 relative">
                        <iframe
                                title="Mapa lokalizacji gabinetu Logorytm"
                                src="https://maps.google.com/maps?q=%C5%81%C4%99ka%20184%2C%2033-322%20Korzenna&t=&z=13&ie=UTF8&iwloc=&output=embed"
                                width="100%"
                                height="100%"
                                style="border:0;"
                                allowfullscreen=""
                                loading="lazy"
                                referrerpolicy="no-referrer-when-downgrade"
                                class="absolute inset-0 grayscale-[0.2] contrast-[1.1]"
                        ></iframe>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <div id="lightbox"
         class="fixed inset-0 z-[10000] bg-[#884A39]/98 backdrop-blur-2xl flex items-center justify-center p-4 md:p-12 opacity-0 pointer-events-none transition-all duration-300">
        <button id="close-lightbox"
                aria-label="Zamknij podgląd zdjęcia"
                class="absolute top-8 right-8 text-white hover:text-[#C38154] transition-colors p-2 z-[10001]">
            <svg aria-hidden="true" class="w-10 h-10" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
            </svg>
        </button>
        <img id="lightbox-img" src="" alt=""
             class="max-w-full max-h-[90vh] rounded-2xl shadow-[0_0_50px_rgba(0,0,0,0.5)] transition-transform duration-300 scale-90 object-contain"/>
    </div>
</Layout>

<style is:global>
    .reveal-up {
        opacity: 0;
        transform: translateY(40px);
        transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
    }

    .reveal-left {
        opacity: 0;
        transform: translateX(-50px);
        transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
    }

    .reveal-right {
        opacity: 0;
        transform: translateX(50px);
        transition: all 0.8s cubic-bezier(0.5, 0, 0, 1);
    }

    .reveal-up.active, .reveal-left.active, .reveal-right.active {
        opacity: 1;
        transform: translate(0);
    }

    body.lightbox-open {
        overflow: hidden;
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const observer = new IntersectionObserver((entries) => {
            entries.forEach(entry => {
                if (entry.isIntersecting) entry.target.classList.add('active');
            });
        }, {threshold: 0.1});
        document.querySelectorAll('.reveal-up, .reveal-left, .reveal-right').forEach(el => observer.observe(el));

        const lightbox = document.getElementById('lightbox');
        const lightboxImg = document.getElementById('lightbox-img') as HTMLImageElement;
        const closeBtn = document.getElementById('close-lightbox');
        const galleryImgs = document.querySelectorAll('.gallery-img');

        if (lightbox) {
            document.body.appendChild(lightbox);
        }

        const openLightbox = (src: string, alt: string) => {
            if (!lightbox || !lightboxImg) return;

            lightboxImg.src = src;
            lightboxImg.alt = alt;

            lightbox.classList.remove('opacity-0', 'pointer-events-none');
            setTimeout(() => {
                lightboxImg.classList.replace('scale-90', 'scale-100');
            }, 10);
            document.body.style.overflow = 'hidden';
        };

        const closeLightbox = () => {
            if (!lightbox || !lightboxImg) return;
            lightboxImg.classList.replace('scale-100', 'scale-90');
            lightbox.classList.add('opacity-0', 'pointer-events-none');

            document.body.style.overflow = '';
        };

        galleryImgs.forEach(img => {
            img.parentElement?.addEventListener('click', (e) => {
                e.preventDefault();
                const imgEl = img as HTMLImageElement;
                openLightbox(imgEl.src, imgEl.alt);
            });
        });
        closeBtn?.addEventListener('click', closeLightbox);
        lightbox?.addEventListener('click', (e) => {
            if (e.target === lightbox) closeLightbox();
        });
        document.addEventListener('keydown', (e) => {
            if (e.key === 'Escape') closeLightbox();
        });
    });
</script>