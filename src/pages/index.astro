---
import Layout from '../layouts/Layout.astro';
import {Image} from 'astro:assets';
import mainPortret from '../assets/mainPortret.jpg';
import img1 from '../assets/img1.jpg';
import img2 from '../assets/img2.jpg';
import img3 from '../assets/img3.png';

const services = [
    {
        title: 'Innowacyjne techniki terapeutyczne',
        description: 'Łączę najnowszą wiedzę logopedyczną z innowacyjnymi narzędziami wspomagającymi, takimi jak elektrostymulacja czy kinesiotaping. Dzięki temu korekcja wad wymowy i praca nad płynnością stają się nie tylko skuteczniejsze, ale i bardziej fascynujące dla pacjenta.',
        image: img1,
        color: '#C38154',
        span: 'col-span-1 md:col-span-2 row-span-2',
        height: 'min-h-[400px] md:min-h-[500px]'
    },
    {
        title: 'Nauka czytania',
        description: 'Wsparcie w nabywaniu umiejętności czytania ze zrozumieniem.',
        image: img2,
        color: '#FFC26F',
        span: 'col-span-1',
        height: 'min-h-[250px]'
    },
    {
        title: 'Terapia Logopedyczna',
        description: 'Przyjazne zajęcia wspierające rozwój mowy',
        image: img3,
        color: '#F9E0BB',
        span: 'col-span-1',
        height: 'min-h-[250px]'
    },
];

const steps = [
    {num: '01', title: 'Wywiad i Diagnoza', desc: 'Szczegółowa rozmowa i badanie narządów artykulacyjnych.'},
    {num: '02', title: 'Indywidualny Plan', desc: 'Ułożenie programu terapii dopasowanego do potrzeb pacjenta.'},
    {num: '03', title: 'Regularna Terapia', desc: 'Systematyczne spotkania i ćwiczenia w przyjaznej atmosferze.'},
];
---

<Layout title="LOGORYTM | Gabinet Logopedyczny | Logopeda - Joanna Jachowicz | Nowy Sącz | Korzenna | Grybów ">
    <section class="relative min-h-[95vh] flex items-center overflow-hidden pt-20">
        <div class="max-w-7xl mx-auto px-6 w-full relative z-10 grid lg:grid-cols-12 gap-12 lg:gap-20 items-center py-12">

            <div class="lg:col-span-6 hero-reveal-left">
                <div class="inline-flex items-center gap-3 bg-white/70 backdrop-blur-md px-5 py-2 rounded-full shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-8 border border-white/50">
                    <span class="w-2.5 h-2.5 rounded-full bg-[#FFC26F] animate-ping-slow"></span>
                    <p class="text-sm font-semibold tracking-wide text-[#884A39] uppercase">Nowoczesna Logopedia</p>
                </div>

                <h1 class="font-heading font-extrabold text-5xl md:text-6xl lg:text-[5rem] text-[#884A39] leading-[1.05] mb-8 tracking-tight">
                    Odzyskaj <br/>
                    <span class="relative inline-block">
                        <span class="relative z-10 text-transparent bg-clip-text bg-linear-to-r from-[#C38154] to-[#FFC26F]">naturalny rytm</span>
                        <svg class="absolute w-full h-4 -bottom-1 left-0 text-[#F9E0BB]/50 z-0" viewBox="0 0 100 10"
                             preserveAspectRatio="none" aria-hidden="true"><path d="M0 5 Q 50 15 100 5"
                                                                                 stroke="currentColor" stroke-width="4"
                                                                                 fill="none"/></svg>
                    </span>
                    mowy.
                </h1>

                <p class="text-lg md:text-xl text-[#884A39] font-medium leading-relaxed max-w-lg mb-12">
                    Profesjonalna diagnoza i innowacyjna terapia logopedyczna. Wspieram rozwój komunikacyjny dzieci,
                    przełamując bariery z uśmiechem i empatią.
                </p>

                <div class="flex flex-col sm:flex-row gap-4">
                    <a href="/contact"
                       class="group relative inline-flex items-center justify-center bg-[#884A39] text-white px-8 py-4 rounded-full text-base font-bold overflow-hidden transition-all hover:shadow-[0_10px_40px_rgba(136,74,57,0.3)] hover:-translate-y-1">
                        <span class="absolute inset-0 w-full h-full bg-linear-to-r from-transparent via-white/20 to-transparent -translate-x-full group-hover:animate-shimmer"></span>
                        <span class="relative flex items-center gap-2">Umów wizytę <svg
                                class="w-4 h-4 group-hover:translate-x-1 transition-transform" fill="none"
                                viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path
                                stroke-linecap="round"
                                stroke-linejoin="round" stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg></span>
                    </a>
                    <a href="/about"
                       class="inline-flex items-center justify-center px-8 py-4 rounded-full text-base font-bold text-[#884A39] bg-white/60 backdrop-blur-md border border-white/50 hover:bg-white transition-all hover:-translate-y-1 shadow-sm">
                        Poznaj gabinet
                    </a>
                </div>

                <div class="flex flex-wrap items-center gap-4 mt-10 pt-8 border-t border-[#884A39]/10 w-fit">
                    <span class="text-sm font-bold text-[#884A39]/50 uppercase tracking-widest">Znajdziesz mnie na:</span>
                    <div class="flex gap-3">
                        <a href="https://www.facebook.com/profile.php?id=61574499106160" target="_blank"
                           rel="noopener noreferrer" aria-label="Odwiedź nasz profil na Facebooku"
                           class="w-12 h-12 rounded-full bg-white/60 backdrop-blur-md shadow-sm border border-white flex items-center justify-center text-[#884A39] hover:bg-[#C38154] hover:text-white hover:-translate-y-1 transition-all">
                            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd"
                                      d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                                      clip-rule="evenodd"/>
                            </svg>
                        </a>
                        <a href="https://maps.app.goo.gl/voQbtfMRnBYd3W4y5" target="_blank" rel="noopener noreferrer"
                           aria-label="Sprawdź naszą lokalizację na mapie Google"
                           class="w-12 h-12 rounded-full bg-white/60 backdrop-blur-md shadow-sm border border-white flex items-center justify-center text-[#884A39] hover:bg-[#C38154] hover:text-white hover:-translate-y-1 transition-all">
                            <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                <path fill-rule="evenodd"
                                      d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                      clip-rule="evenodd"/>
                            </svg>
                        </a>
                    </div>
                </div>
            </div>

            <div class="lg:col-span-6 relative mt-16 lg:mt-0 hero-reveal-right">
                <div class="relative w-full aspect-4/5 md:aspect-square rounded-[3rem] overflow-hidden shadow-2xl border-8 border-white/80 z-10">
                    <Image
                            src={mainPortret}
                            alt="Terapia logopedyczna"
                            loading="eager"
                            fetchpriority="high"
                            format="avif"
                            widths={[400, 800, 1200]}
                            sizes="(max-width: 768px) 400px, (max-width: 1024px) 800px, 1200px"
                            class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-1000"
                    />
                    <div class="absolute inset-0 bg-linear-to-tr from-[#884A39]/40 via-transparent to-transparent"></div>
                </div>
            </div>

        </div>
    </section>

    <section class="bg-[#884A39] py-12 md:py-16 relative z-20 shadow-2xl">
        <div class="max-w-7xl mx-auto px-6">
            <div class="grid grid-cols-1 md:grid-cols-3 gap-10 md:gap-0 md:divide-x divide-white/10 text-center">
                <div class="reveal-up" style="transition-delay: 100ms">
                    <p class="text-3xl lg:text-4xl font-heading font-bold text-[#FFC26F] mb-1 md:mb-2">Indywidualne</p>
                    <p class="text-xs sm:text-sm font-medium text-white/70 uppercase tracking-wider">Podejście</p>
                </div>
                <div class="reveal-up" style="transition-delay: 200ms">
                    <p class="text-3xl lg:text-4xl font-heading font-bold text-[#FFC26F] mb-1 md:mb-2">Certyfikaty</p>
                    <p class="text-xs sm:text-sm font-medium text-white/70 uppercase tracking-wider">Medyczne</p>
                </div>
                <div class="reveal-up" style="transition-delay: 300ms">
                    <p class="text-3xl lg:text-4xl font-heading font-bold text-[#FFC26F] mb-1 md:mb-2">Nowoczesne</p>
                    <p class="text-xs sm:text-sm font-medium text-white/70 uppercase tracking-wider">Metody terapii</p>
                </div>
            </div>
        </div>
    </section>

    <section class="py-32 relative">
        <div class="max-w-7xl mx-auto px-6">
            <div class="flex flex-col md:flex-row md:items-end justify-between mb-16 reveal-up">
                <div class="max-w-2xl">
                    <span class="text-[#C38154] font-bold tracking-widest uppercase text-sm mb-3 block">Zakres Pomocy</span>
                    <h2 class="font-heading font-extrabold text-4xl md:text-5xl text-[#884A39] leading-tight">W czym
                        mogę <br/> Ci pomóc?</h2>
                </div>
                <a href="/services"
                   class="mt-6 md:mt-0 group inline-flex items-center gap-3 text-[#884A39] font-bold text-lg hover:text-[#C38154] transition-colors">
                    Zobacz pełną ofertę
                    <span class="w-12 h-12 rounded-full bg-white/70 backdrop-blur-md shadow-sm border border-white/50 flex items-center justify-center group-hover:bg-[#C38154] group-hover:text-white transition-all">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path
                                stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3"/></svg>
                    </span>
                </a>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
                {services.map((service, index) => (
                        <div class={`group relative rounded-[2.5rem] overflow-hidden ${service.span} ${service.height} reveal-up shadow-xl`}
                             style={`transition-delay: ${index * 150}ms`}>
                            <Image src={service.image} alt={service.title}
                                   format="avif"
                                   loading="lazy"
                                   widths={[400, 800]}
                                   sizes="(max-width: 768px) 400px, 800px"
                                   class="absolute inset-0 w-full h-full object-cover group-hover:scale-110 transition-transform duration-1000"/>
                            <div class="absolute inset-0 bg-linear-to-t from-[#884A39]/90 via-[#884A39]/40 to-transparent opacity-80 group-hover:opacity-90 transition-opacity duration-500"></div>

                            <div class="absolute inset-0 p-8 md:p-10 flex flex-col justify-end">
                                <div class="transform translate-y-4 group-hover:translate-y-0 transition-transform duration-500">
                                    <div class="w-12 h-1 rounded-full mb-6"
                                         style={`background-color: ${service.color}`}></div>
                                    <h3 class="font-heading font-bold text-3xl text-white mb-3">{service.title}</h3>
                                    <p class="text-white/80 leading-relaxed mb-6 opacity-0 group-hover:opacity-100 transition-opacity duration-500 delay-100 max-w-md">
                                        {service.description}
                                    </p>
                                    <a href="/services"
                                       class="inline-flex items-center gap-2 text-white font-semibold hover:underline decoration-2 underline-offset-4"
                                       style={`text-decoration-color: ${service.color}`}>
                                        Więcej szczegółów
                                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                                             aria-hidden="true">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                                  d="M9 5l7 7-7 7"/>
                                        </svg>
                                    </a>
                                </div>
                            </div>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <section class="py-24 bg-white/40 backdrop-blur-lg border-t border-b border-white/50">
        <div class="max-w-7xl mx-auto px-6">
            <div class="text-center mb-16 reveal-up">
                <h2 class="font-heading font-extrabold text-3xl md:text-4xl text-[#884A39] mb-4">Jak wygląda
                    współpraca?</h2>
                <p class="text-[#884A39]/70 font-medium text-lg">Prosta i przejrzysta droga do płynnej mowy.</p>
            </div>

            <div class="grid md:grid-cols-3 gap-10 relative">
                <div class="hidden md:block absolute top-12 left-[15%] right-[15%] h-0.5 bg-linear-to-r from-[#C38154]/20 via-[#FFC26F]/50 to-[#F9E0BB]/20 z-0"></div>

                {steps.map((step, index) => (
                        <div class="relative z-10 flex flex-col items-center text-center reveal-up"
                             style={`transition-delay: ${index * 200}ms`}>
                            <div class="w-24 h-24 rounded-full bg-white/90 backdrop-blur-md border border-white shadow-xl flex items-center justify-center mb-6 text-2xl font-heading font-bold text-[#C38154]">
                                {step.num}
                            </div>
                            <h3 class="font-bold text-[#884A39] text-xl mb-3">{step.title}</h3>
                            <p class="text-[#884A39]/70 leading-relaxed max-w-xs">{step.desc}</p>
                        </div>
                ))}
            </div>
        </div>
    </section>

    <section class="py-32 bg-[#884A39] relative overflow-hidden">
        <svg class="absolute -top-px left-0 w-full opacity-10" viewBox="0 0 1440 320" aria-hidden="true"
             xmlns="http://www.w3.org/2000/svg">
            <path fill="#ffffff" fill-opacity="1"
                  d="M0,128L48,138.7C96,149,192,171,288,165.3C384,160,480,128,576,133.3C672,139,768,181,864,197.3C960,213,1056,203,1152,181.3C1248,160,1344,128,1392,112L1440,96L1440,0L1392,0C1344,0,1248,0,1152,0C1056,0,960,0,864,0C768,0,672,0,576,0C480,0,384,0,288,0C192,0,96,0,48,0L0,0Z"></path>
        </svg>

        <div class="max-w-7xl mx-auto px-6">
            <div class="grid lg:grid-cols-2 gap-16 items-center">
                <div class="relative reveal-left">
                    <div class="relative w-full max-w-112.5 mx-auto">
                        <div class="absolute inset-0 bg-[#FFC26F] transform rotate-3 rounded-[3rem] opacity-20"></div>
                        <div class="absolute inset-0 bg-[#C38154] transform -rotate-3 rounded-[3rem] opacity-20"></div>

                        <div class="relative aspect-[3/4] rounded-[3rem] overflow-hidden shadow-2xl border-4 border-[#884A39]">
                            <Image
                                    src={mainPortret}
                                    alt="Joanna Jachowicz - logopeda"
                                    loading="lazy"
                                    format="avif"
                                    widths={[400, 800, 1200]}
                                    sizes="(max-width: 768px) 400px, (max-width: 1024px) 800px, 1200px"
                                    class="w-full h-full object-cover scale-105 hover:scale-100 transition-transform duration-1000"
                            />
                        </div>
                    </div>
                </div>

                <div class="reveal-right text-white">
                    <p class="text-sm font-bold tracking-widest text-[#FFC26F] uppercase mb-4">Poznajmy się</p>
                    <h2 class="font-heading font-extrabold text-4xl md:text-5xl mb-8 leading-tight">
                        Terapia oparta na <span class="text-[#FFC26F]">wiedzy</span> i relacji.
                    </h2>
                    <div class="space-y-6 text-lg text-white/80 leading-relaxed mb-10">
                        <p>
                            Nazywam się <strong>Joanna Jachowicz</strong> i jestem logopedą, dla którego wspieranie
                            rozwoju najmłodszych to pasja i codzienna radość. Pomagam dzieciom pokonywać trudności w
                            mówieniu, by mogły z odwagą, pewnością siebie i uśmiechem dzielić się swoimi myślami z
                            rówieśnikami oraz bliskimi.
                        </p>
                        <p>
                            Mój gabinet <em>Logorytm</em> to miejsce stworzone z myślą o emocjach i potrzebach dziecka.
                            Wierzę, że najpiękniejsze postępy rodzą się tam, gdzie nauka staje się przygodą, a terapia
                            opiera się na zabawie, wzajemnym zaufaniu i pełnym poczuciu bezpieczeństwa.
                        </p>
                        <p>
                            W pracy stawiam na rzetelną wiedzę i partnerską współpracę z rodzicami, bo to właśnie
                            wspólne działania pozwalają stworzyć dziecku najlepsze warunki do rozkwitu jego mowy.
                        </p>
                    </div>

                    <div class="flex flex-col sm:flex-row items-start sm:items-center gap-6">
                        <a href="/about"
                           class="inline-flex items-center gap-3 text-[#FFC26F] font-bold text-lg hover:text-white transition-colors group">
                            Więcej o moim doświadczeniu
                            <svg class="w-5 h-5 group-hover:translate-x-2 transition-transform" fill="none"
                                 viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                      d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                            </svg>
                        </a>

                        <div class="h-6 w-px bg-white/20 hidden sm:block"></div>

                        <div class="flex gap-3">
                            <a href="https://www.facebook.com/profile.php?id=61574499106160" target="_blank"
                               rel="noopener noreferrer" aria-label="Odwiedź nasz profil na Facebooku"
                               class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[#C38154] hover:-translate-y-1 transition-all">
                                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path fill-rule="evenodd"
                                          d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"
                                          clip-rule="evenodd"/>
                                </svg>
                            </a>
                            <a href="https://maps.app.goo.gl/9VgHfHr2W2wW14uB7" target="_blank"
                               rel="noopener noreferrer" aria-label="Sprawdź naszą lokalizację na mapie Google"
                               class="w-12 h-12 rounded-full bg-white/10 flex items-center justify-center text-white hover:bg-[#C38154] hover:-translate-y-1 transition-all">
                                <svg class="w-7 h-7" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
                                    <path fill-rule="evenodd"
                                          d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"
                                          clip-rule="evenodd"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <section class="py-24 relative overflow-hidden">
        <div class="max-w-5xl mx-auto px-6 reveal-up">
            <div class="bg-white/60 backdrop-blur-2xl rounded-[3rem] p-10 md:p-20 text-center relative overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.05)] border border-white/60">

                <div class="relative z-10">
                    <span class="inline-block p-4 rounded-full bg-white/90 backdrop-blur-sm text-[#C38154] mb-6 shadow-sm border border-white">
                        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                                  d="M14.828 14.828a4 4 0 01-5.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
                        </svg>
                    </span>
                    <h3 class="font-heading font-extrabold text-4xl md:text-5xl text-[#884A39] mb-6 leading-tight">
                        Zadbaj o mowę <br/> Twojego dziecka.
                    </h3>
                    <p class="text-xl text-[#884A39]/70 mb-12 max-w-2xl mx-auto">
                        Zapraszam na konsultację, na której w przyjaznej atmosferze sprawdzimy, jak mogę pomóc Waszej
                        rodzinie.
                    </p>
                    <div class="flex flex-col sm:flex-row gap-4 justify-center">
                        <a href="/contact"
                           class="bg-[#C38154] text-white px-10 py-4 rounded-full text-lg font-bold hover:bg-[#884A39] transition-all duration-300 shadow-xl hover:-translate-y-1">
                            Umów się na spotkanie
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </section>

</Layout>

<style is:global>
    .animate-pulse-slow {
        animation: pulse 8s cubic-bezier(0.4, 0, 0.6, 1) infinite;
    }

    .animate-float {
        animation: float 6s ease-in-out infinite;
    }

    .animate-shimmer {
        animation: shimmer 2s infinite linear;
    }

    @keyframes float {
        0% {
            transform: translateY(0px);
        }
        50% {
            transform: translateY(-15px);
        }
        100% {
            transform: translateY(0px);
        }
    }

    @keyframes shimmer {
        100% {
            transform: translateX(100%);
        }
    }

    .slide-up-delayed {
        animation: floatUp 1s cubic-bezier(0.5, 0, 0, 1) 0.8s forwards;
        opacity: 0;
        transform: translateY(30px);
    }

    @keyframes floatUp {
        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>