---
import {Image} from 'astro:assets';
import logoSymbol from '../../public/logorytm-logo.png';

const year = new Date().getFullYear();
const footerLinks = [
    {name: 'Strona główna', href: '/'},
    {name: 'O mnie', href: '/about'},
    {name: 'Oferta', href: '/services'},
    {name: 'Cennik', href: '/pricing'},
    {name: 'Kontakt', href: '/contact'},
];
---

<footer class="bg-white/40 backdrop-blur-md border-t border-[#884A39]/10 mt-20 relative z-10">
    <div class="max-w-7xl mx-auto px-6 py-16 grid grid-cols-1 md:grid-cols-3 gap-12 text-center md:text-left">
        <div>
            <a href="/" class="group flex items-center justify-center md:justify-start gap-3 mb-6 py-2">
                <Image
                        src={logoSymbol}
                        alt="LOGORYTM Symbol"
                        width={200}
                        quality="max"
                        loading="lazy"
                        class="w-auto h-12 md:h-14 opacity-90 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300"
                />
                <div class="flex flex-col items-center text-center">
                    <span class="font-heading font-extrabold text-3xl md:text-4xl text-transparent bg-clip-text bg-gradient-to-r from-[#884A39] to-[#C38154] tracking-tight">LOGORYTM</span>
                    <span class="font-medium text-xs text-[#884A39]/90 mt-1 text-nowrap">LOGOPEDIA I TERAPIA MOWY</span>
                    <span class="font-medium text-xs text-[#884A39]/90">JOANNA JACHOWICZ</span>
                </div>
            </a>

            <p class="text-[#884A39] text-sm leading-relaxed font-medium">
                Odzyskaj naturalny rytm mowy.
            </p>
        </div>

        <div class="md:pt-2">
            <h4 class="font-heading font-bold text-lg tracking-wide text-[#884A39] mb-6 uppercase">Kontakt</h4>
            <div class="space-y-4">
                <a href="tel:+48504759254"
                   class="group flex items-center justify-center md:justify-start gap-3 text-[#884A39] text-sm font-medium hover:text-[#C38154] transition-all py-1">
                    <svg aria-hidden="true" class="w-6 h-6 text-[#C38154]" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                    </svg>
                    (+48) 504 759 254
                </a>
                <a href="mailto:kontaktlogorytm@gmail.com"
                   class="group flex items-center justify-center md:justify-start gap-3 text-[#884A39] text-sm font-medium hover:text-[#C38154] transition-all py-1">
                    <svg aria-hidden="true" class="w-6 h-6 text-[#C38154]" fill="none" viewBox="0 0 24 24"
                         stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                    </svg>
                    kontaktlogorytm@gmail.com
                </a>
                <div class="flex items-start justify-center md:justify-start gap-3 text-[#884A39] text-sm font-medium py-1">
                    <svg aria-hidden="true" class="w-6 h-6 text-[#C38154] shrink-0 mt-0.5" fill="none"
                         viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                              d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                    </svg>
                    <a href="https://www.google.com/maps/place/LOGORYTM+Gabinet+Logopedyczny+Joanna+Jachowicz/@49.6507981,20.7461969,13z/data=!4m6!3m5!1s0x473deff9ea8b45d9:0xaf9a67dc9a6dd3a0!8m2!3d49.6731642!4d20.7784393!16s%2Fg%2F11nbzlh9vv?authuser=0&entry=ttu&g_ep=EgoyMDI2MDQxMi4wIKXMDSoASAFQAw%3D%3D"
                       target="_blank" rel="noopener noreferrer" class="hover:text-[#C38154] transition-colors">
                        Łęka 184,<br/>33-322 Korzenna
                    </a>
                </div>
            </div>
        </div>

        <div class="md:pt-2">
            <h4 class="font-heading font-bold text-lg tracking-wide text-[#884A39] mb-5 uppercase">Na skróty</h4>
            <nav class="space-y-3">
                {footerLinks.map((link) => (
                        <a href={link.href}
                           class="group flex items-center justify-center md:justify-start text-[#884A39] text-sm font-medium hover:text-[#C38154] transition-colors py-1">
                            <span class="w-0 h-[2px] bg-[#C38154] mr-0 group-hover:w-4 group-hover:mr-2 transition-all duration-300"></span>
                            {link.name}
                        </a>
                ))}
            </nav>
        </div>
    </div>

    <div class="max-w-7xl mx-auto px-6 py-8 border-t border-[#884A39]/10 text-center flex flex-col xl:flex-row justify-between items-center gap-6">
        <div class="flex flex-col md:flex-row items-center gap-4 text-xs text-[#884A39]/70 font-medium">
            <p>© {year} LOGORYTM Gabinet Logopedyczny. Wszelkie prawa zastrzeżone.</p>
            <span class="hidden md:block w-1 h-1 rounded-full bg-[#884A39]/30"></span>
            <p>Wykorzystano grafiki z <a href="https://pl.freepik.com/" target="_blank" rel="noopener noreferrer"
                                         class="hover:text-[#C38154] transition-colors underline decoration-1 underline-offset-2 p-1">Freepik</a>
            </p>
        </div>

        <div class="flex flex-wrap justify-center items-center gap-2">
            <span class="px-3 py-1.5 rounded-full bg-[#C38154]/10 text-[#C38154] font-bold text-[10px] tracking-widest uppercase border border-[#C38154]/20 shadow-sm">Nowy Sącz</span>
            <span class="px-3 py-1.5 rounded-full bg-[#C38154]/10 text-[#C38154] font-bold text-[10px] tracking-widest uppercase border border-[#C38154]/20 shadow-sm">Korzenna</span>
            <span class="px-3 py-1.5 rounded-full bg-[#C38154]/10 text-[#C38154] font-bold text-[10px] tracking-widest uppercase border border-[#C38154]/20 shadow-sm">Łęka</span>
            <span class="px-3 py-1.5 rounded-full bg-[#C38154]/10 text-[#C38154] font-bold text-[10px] tracking-widest uppercase border border-[#C38154]/20 shadow-sm">Grybów</span>
        </div>

        <a href="/privacy" class="text-xs text-[#884A39] font-medium hover:text-[#884A39]/90 transition-colors p-2 shrink-0">
            Polityka prywatności
        </a>
    </div>
</footer>