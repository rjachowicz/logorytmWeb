---
import '../styles/global.css';
import '@fontsource-variable/inter';
import '@fontsource-variable/montserrat';
import '@fontsource/poppins/500.css';
import '@fontsource/poppins/600.css';
import '@fontsource/poppins/700.css';
import '@fontsource/poppins/800.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
    title: string;
    preloadImage?: string;
}

const {title, preloadImage} = Astro.props;
---

<html lang="pl">
<head>
    <meta charset="UTF-8"/>
    <meta name="description" content="Gabinet Logopedyczny Logorytm - profesjonalna terapia wad wymowy."/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <link rel="icon" type="image/png" href="/logorytm-logo.png"/>
    <link rel="apple-touch-icon" href="/logorytm-logo-background.png"/>
    <meta name="generator" content={Astro.generator}/>
    <title>{title} | Logorytm Gabinet Logopedyczny</title>

    {preloadImage &&
            <link rel="preload" as="image" href={preloadImage} fetchpriority="high"/>}

    <meta property="og:type" content="website"/>
    <meta property="og:title" content={`${title} | Logorytm Gabinet Logopedyczny`}/>
    <meta property="og:description" content="Gabinet Logopedyczny Logorytm - profesjonalna terapia wad wymowy."/>
    <meta property="og:image" content="/logorytm-logo-background.png"/>
    <meta property="og:url" content={Astro.url}/>
    <link rel="canonical" href={Astro.url}/>
</head>
<body class="font-sans text-[#884A39] antialiased relative selection:bg-[#C38154] selection:text-white">
<div class="fixed inset-0 z-[-1] overflow-hidden bg-[#FDFBF7] pointer-events-none">
    <div class="absolute top-[-10%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-[#C38154]/20 blur-[60px] md:blur-[120px] mix-blend-multiply md:animate-blob"></div>
    <div class="absolute top-[20%] right-[-10%] w-[45vw] h-[45vw] rounded-full bg-[#FFC26F]/20 blur-[50px] md:blur-[100px] mix-blend-multiply md:animate-blob md:animation-delay-2000"></div>
    <div class="absolute bottom-[-20%] left-[10%] w-[60vw] h-[60vw] rounded-full bg-[#884A39]/15 blur-[60px] md:blur-[130px] mix-blend-multiply md:animate-blob md:animation-delay-4000"></div>
</div>

<div class="sticky top-0 z-50">
    <Header/>
</div>

<main class="relative z-10">
    <slot/>
</main>

<Footer/>

<div id="cookie-overlay"
     class="fixed inset-0 z-[9999] flex items-center justify-center p-6 bg-[#884A39]/20 backdrop-blur-sm opacity-0 pointer-events-none transition-all duration-500">
    <div id="cookie-modal"
         class="bg-white/95 backdrop-blur-2xl p-8 md:p-10 rounded-[2.5rem] shadow-[0_20px_50px_rgba(0,0,0,0.1)] border border-white max-w-lg w-full transform scale-90 transition-all duration-500">
        <div class="text-center">
            <div class="w-16 h-16 bg-[#F9E0BB] rounded-full flex items-center justify-center mx-auto mb-6 text-[#C38154]">
                <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                          d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
            </div>
            <h3 class="font-heading font-extrabold text-2xl text-[#884A39] mb-4">Dbamy o Twoją prywatność</h3>
            <p class="text-[#884A39]/80 font-medium leading-relaxed mb-8">
                Nasza strona wykorzystuje pliki cookies, aby zapewnić Ci najlepsze doświadczenia, w tym do poprawnego
                działania Map Google i wyświetlania pięknych czcionek.
                Dalsze korzystanie z serwisu oznacza zgodę na ich użycie.
            </p>
            <div class="flex flex-col gap-3">
                <button id="accept-cookies"
                        class="w-full bg-[#C38154] text-white px-8 py-4 rounded-full text-base font-bold hover:bg-[#884A39] transition-all shadow-lg hover:-translate-y-1">
                    Rozumiem i akceptuję
                </button>
                <a href="/privacy"
                   class="text-sm font-bold text-[#884A39]/60 hover:text-[#C38154] transition-colors uppercase tracking-widest">
                    Polityka Prywatności
                </a>
            </div>
        </div>
    </div>
</div>

</body>
</html>

<style is:global>
    .animate-blob {
        animation: blob 15s infinite alternate cubic-bezier(0.4, 0, 0.2, 1);
    }

    .animation-delay-2000 {
        animation-delay: 2s;
    }

    .animation-delay-4000 {
        animation-delay: 4s;
    }

    @keyframes blob {
        0% {
            transform: translate(0px, 0px) scale(1);
        }
        33% {
            transform: translate(50px, -50px) scale(1.1);
        }
        66% {
            transform: translate(-40px, 40px) scale(0.9);
        }
        100% {
            transform: translate(0px, 0px) scale(1);
        }
    }

    #cookie-overlay.active {
        opacity: 1;
        pointer-events: auto;
    }

    #cookie-overlay.active #cookie-modal {
        transform: scale(1);
    }
</style>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const overlay = document.getElementById('cookie-overlay');
        const acceptButton = document.getElementById('accept-cookies');

        if (!localStorage.getItem('cookiesAccepted')) {
            setTimeout(() => {
                overlay?.classList.add('active');
            }, 800);
        }

        acceptButton?.addEventListener('click', () => {
            localStorage.setItem('cookiesAccepted', 'true');
            overlay?.classList.remove('active');
        });
    });
</script>